@model ItemSubcategory
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="border p-3 mt-4">
    <div class="row pb-2">
        <h2 class="text-primary">Edit Subcategory</h2>
        <hr />
    </div>
    <div class="col-sm-8">
        <select class="form-select" id="category" required>
        </select>
    </div>
    <div class="mb-3 row p-1">
        <label class="p-0">Subcategory Name</label>
        <input id="name" type="text" class="form-control" value="@Model?.Name" />
        <span id="error" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-6 col-md-3">
            <p onclick="submit()" class="btn btn-primary form-control">Submit Changes</p>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Subcategories" asp-action="Index" class="btn btn-secondary form-control">Back</a>
        </div>
    </div>

</div>

<script>
    window.onload = function() {
        $.ajax(
            {
                url: '@Url.Action("PopulateCategoryDropdown", "User")',
                method: "GET",
                success: function (data, textStatus, jqXHR) {
                    const catDropdown = $("#category");
                    if(data.length > 0) {
                        data.forEach(x=> {
                            catDropdown.append(`<option value="${x.categoryID}">${x.name}</option>`);
                        });
                        catDropdown.val("@(Model?.CategoryID)");
                    }
                    else {
                        catDropdown.append('<option value="-1">Unable to retrieve categories</option>')
                    }
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    alert("Unable to process request.\nPlease try again later or contact administrator.")
                }
            });
    }
    function submit() {
       const categoryElement = $("#category");
       const nameElement =  $("#name");
       let name = nameElement.val();
       let categoryId = categoryElement.val();
       if(categoryId && categoryId != -1) {
           let payload = {'subcategoryId': @Model.SubcategoryID, 'name': name, 'categoryId': categoryId};
           //alert(name)
           $.ajax(
                {
                    url: '@Url.Action("Edit", "Subcategories")',
                    method: "POST",
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    data: JSON.stringify(payload),
                    success: function (data, textStatus, jqXHR) {
                        window.location.href = "/subcategories/index"
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        alert("Unable to process request.\nPlease try again later or contact administrator.")
                    }
                });
       }
       else {
           alert("Please select a category");
       }
    }
</script>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}