@model CapstoneProject.ViewModels.MyRequestDetailsViewModel

@{
    ViewData["Title"] = "Request Details";
}

<div class="container mt-4">
    <h2 class="mb-4">Request Details</h2>

    <div class="mb-3">
        <strong>Request ID:</strong> @Model.TransactionID
    </div>
    <div class="mb-3">
        <strong>Date:</strong> @Model.Date
    </div>
    <div class="mb-3">
        <strong>Status:</strong>
        @if (Model.Status == "Processed")
        {
            <span class="badge bg-success">@Model.Status</span>
        }
        else
        {
            <span class="badge bg-warning text-dark">@Model.Status</span>
        }
    </div>
    <div class="mb-3">
        <strong>Special Requests:</strong>
        @(string.IsNullOrWhiteSpace(Model.SpecialRequests) ? "None" : Model.SpecialRequests)
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Item ID</th>
                <th>Description</th>
                <th>Quantity</th>
                <th>Point Cost</th>
                <th>Line Total</th>
                <th>RG</th>
                <th>PAL</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ItemID</td>
                    <td>@item.Description</td>
                    <td>@item.Quantity</td>
                    <td>@item.PointCost</td>
                    <td>@(item.PointCost * (int)item.Quantity)</td>
                    <td>@(item.IsRG ? "Yes" : "No")</td>
                    <td>@(item.IsPAL ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <strong>Additional Point Cost:</strong> @Model.AdditionalPointCost
    </div>
    <div class="mt-2">
        <strong>Total Cost:</strong> @Model.TotalCost
    </div>

    <div class="mt-4">
        <a asp-controller="User" asp-action="MyRequests" class="btn btn-secondary">
            Back to My Requests
        </a>
    </div>
</div>