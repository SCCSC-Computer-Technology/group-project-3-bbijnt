@model CapstoneProject.Areas.Identity.Data.CapstoneProjectUser;
@{
    ViewData["Title"] = "Student Application";
}


<head>
    <style>
        .btn-custom-blue {
            background-color: #242c5c;
            border-color: #242c5c;
            color: white;
        }

            .btn-custom-blue:hover {
                background-color: #349444;
                border-color: #349444;
                color: white;
            }
    </style>
</head>﻿

<div class="container">
    <div class="d-flex align-items-center">
        <img src="/Images/logo.png" class="img-thumbnail d-inline me-4" alt="Chaser Logo" style="max-width: 300px;">
    </div>
    <h1 class="text-end mb-5">USER <span class="text-success">APPLICATION</span></h1>
    <h2 class="mb-4">Please provide the following information:</h2>
@*      <form method="post">*@
    <form asp-controller="Registration" asp-action="UserApplicationForm" method="post" class="form-bottom-margin">
        <input hidden asp-for="Email" />
        <div class="row mb-4">


            <label for="UserID" class="col-sm-2 col-form-label">SCC ID</label>
            <div class="col-sm-10">
                
                <input asp-for="StudentId" class="form-control" >
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-4">
            @*<label for="FirstName" class="col-sm-2 col-form-label">First Name</label>*@
            <label asp-for="FirstName" class="col-sm-2 col-form-label">
                @Html.DisplayNameFor(model => model.FirstName)
            </label>
            <div class="col-sm-10">
               
                <input asp-for="FirstName" class="form-control" required>
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-4">
            <label for="LastName" class="col-sm-2 col-form-label">Last Name</label>
            <div class="col-sm-10">
               
                <input asp-for="LastName" class="form-control" required>
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-4">
            <label for="DOB" class="col-sm-2 col-form-label">Date of Birth</label>
            <div class="col-sm-10">
                
                <input asp-for="DOB" class="form-control" minLength=10 maxlength="10" required>
                <span asp-validation-for="DOB" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-4">
            <label for="PhoneNum" class="col-sm-2 col-form-label">Phone Number</label>
            <div class="col-sm-10">
                <input asp-for="PhoneNum" type="tel" class="form-control" id="PhoneNum" minLength="10" maxlength="10" required>
                <span asp-validation-for="PhoneNum" class="text-danger"></span>
            </div>
        </div>
        <h3>Ethnicity: (check all that apply)</h3>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="EthAfricanAmerican" >
                    <label class="form-check-label" asp-for="EthAfricanAmerican">African American</label>
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="EthAsian" >
                    <label class="form-check-label" asp-for="EthAsian">Asian</label>
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                     <input class="form-check-input" asp-for="EthCaucasian" >
                    <label class="form-check-label" asp-for="EthCaucasian">Caucasian</label>
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                     <input class="form-check-input" asp-for="EthLatino" >
                    <label class="form-check-label" asp-for="EthLatino">Latino</label>
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                     <input class="form-check-input" asp-for="EthMiddleEastern" >
                    <label class="form-check-label" asp-for="EthMiddleEastern">Middle Eastern</label>
                </div>
            </div>

            <div class="row mb-3">

                <div class="col-6 col-md-2 mb-3">
                    <div class="form-check form-checkform-check-inline">
                        
                         <input class="form-check-input" asp-for="EthNativeAmerican" >
                        <label class="form-check-label" asp-for="EthNativeAmerican">Native American</label>
                    </div>
                </div>

                <div class="col-6 col-md-2 mb-3">
                    <div class="form-check form-checkform-check-inline">
                       
                         <input class="form-check-input" asp-for="EthPacificIslander" >
                        <label class="form-check-label" asp-for="EthPacificIslander">Pacific Islander</label>
                    </div>
                </div>

                <div class="col-6 col-md-2 mb-3">
                    <div class="form-check form-checkform-check-inline">
                       
                         <input class="form-check-input" asp-for="EthOther" >
                        <label class="form-check-label" asp-for="EthOther">Other</label>
                    </div>
                </div>
            </div>
        </div>
        <h4>Gender: </h4>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                    
                    <input class="form-check-input" asp-for="Gender" type="radio" id="Gender" value="male" >
                    <label class="form-check-label" asp-for="Gender">Male</label> 
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                   
                    <input class="form-check-input" asp-for="Gender" type="radio" id="Gender" value="female" >
                    <label class="form-check-label" asp-for="Gender">Female</label> 
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                    
                    <input class="form-check-input" asp-for="Gender" type="radio" id="Gender" value="transgender" >
                    <label class="form-check-label" asp-for="Gender">Transgender</label> 
                </div>
            </div>
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                    
                    <input class="form-check-input" asp-for="Gender" type="radio" id="Gender" value="n/a" >
                    <label class="form-check-label" asp-for="Gender">Prefer not to say</label> 
                </div>
            </div>
        </div>

      <h5>Student Status: </h5>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                    
                    <input class="form-check-input" asp-for="StudentStatus" type="radio" id="StudentStatus" value="fullTime" >
                    <label class="form-check-label" asp-for="StudentStatus">Full-Time</label> 
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                   
                    <input class="form-check-input" asp-for="StudentStatus" type="radio" id="StudentStatus" value="partTime" >
                    <label class="form-check-label" asp-for="StudentStatus">Part-Time</label> 
                </div>
            </div>           
        </div>

        <h6>Campus you attend: (check all that apply) </h6>
        <div class="row mb-3">
            <div class="col-6 col-md-3 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="AttendsSpartanburg" >
                    <label class="form-check-label" asp-for="AttendsSpartanburg">Spartanburg(Giles)</label>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="AttendsDowntown" >
                    <label class="form-check-label" asp-for="AttendsDowntown">Downtown(Evans)</label>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="AttendsCherokee" >
                    <label class="form-check-label" asp-for="AttendsCherokee">Cherokee</label>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="AttendsTygerRiver" >
                    <label class="form-check-label" asp-for="AttendsTygerRiver">Tyger River</label>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="AttendsUnion" >
                    <label class="form-check-label" asp-for="AttendsUnion">Union</label>
                </div>
            </div>
        </div>
        <h7>How many people in your household are:</h7>
        <div class="row mb-3">
           
            <label for="HouseholdBabiesToddlers" class="col-sm-2 col-form-label text-end">Age 0-4</label>
            <div class="col-sm-2">
                <input asp-for="HouseholdBabiesToddlers" class="form-control" id="HouseholdBabiesToddlers">
                <span asp-validation-for="HouseholdBabiesToddlers" class="text-danger"></span>
            </div>
           
            <label for="HouseholdBabiesChildren" class="col-sm-2 col-form-label text-end">Age 5-12</label>
            <div class="col-sm-2">
                <input asp-for="HouseholdBabiesChildren" class="form-control"  id="HouseholdBabiesChildren" >
                <span asp-validation-for="HouseholdBabiesChildren" class="text-danger"></span>
            </div>

            

            <label for="HouseholdTeens" class="col-sm-2 col-form-label text-end">Age 13-17</label>
            <div class="col-sm-2">
                <input asp-for="HouseholdTeens " class="form-control" id="HouseholdTeens">
                <span asp-validation-for="HouseholdTeens" class="text-danger"></span>
            </div>

            

            <label for="HouseholdAdults" class="col-sm-2 col-form-label text-end">Age 18+</label>
            <div class="col-sm-2">
                <input asp-for="HouseholdAdults" class="form-control"  id="HouseholdAdults">
                <span asp-validation-for="HouseholdAdults" class="text-danger"></span>
            </div>

        </div>
        <h8>Do you have transportation: </h8>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">

                    <input class="form-check-input" type="radio" asp-for="HasTransportation" value="true" id="HasTransportationTrue">
                     <label class="form-check-label" asp-for="HasTransportation">Yes</label>
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">

                    <input class="form-check-input" type="radio" asp-for="HasTransportation" value="false" id="HasTransportationFalse">
                    <label class="form-check-label" asp-for="HasTransportation">No</label>
                </div>

            </div>
        </div>
        <h9>Are you employed: </h9>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                   
                     <input class="form-check-input" asp-for="Employed" type="radio" id="Employed" value="fullTime" >
                    <label class="form-check-label" asp-for="Employed">Full-Time</label> 
                </div>
            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                   
                    <input class="form-check-input" asp-for="Employed" type="radio" id="Employed" value="partTime" >
                    <label class="form-check-label" asp-for="Employed">Part-Time</label> 
                </div>

            </div>

            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-check-inline">
                   
                    <input class="form-check-input" asp-for="Employed" type="radio" id="Employed" value="No" >
                    <label class="form-check-label" asp-for="Employed">No</label> 
                </div>

            </div>
        </div>
        <div class="mb-3 row">
             <label for="EmployedHouseMemebers" class="col-sm-2 col-form-label text-end">How many people in your household are employeed?</label>
            <div class="col-sm-2">
                <input asp-for="EmployedHouseMembers" class="form-control" id="EmployedHouseMembers">
                <span asp-validation-for="EmployedHouseMembers" class="text-danger"></span>
            </div>
        </div>
        <h10>Which benefit(s) do you or someone in your household recieve: (Check all that apply)</h10>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="HasSNAP">
                    <label class="form-check-label" asp-for="HasSNAP">SNAP</label>
                </div>
            </div>
              <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="HasWIC">
                    <label class="form-check-label" asp-for="HasWIC">WIC</label>
                </div>
              </div>
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="HasTANF">
                    <label class="form-check-label" asp-for="HasTANF">TANF</label>
                </div>
            </div>
       </div>
               <h10>If your household does not receive any of these programs and you are interested in learning about them: (Check all that apply)</h10>
        <div class="row mb-3">
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="IsInterestedInSNAP">
                    <label class="form-check-label" asp-for="IsInterestedInSNAP">SNAP</label>
                </div>
            </div>
              <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                   
                    <input class="form-check-input" asp-for="IsInterestedInWIC">
                    <label class="form-check-label" asp-for="IsInterestedInWIC">WIC</label>
                </div>
              </div>
            <div class="col-6 col-md-2 mb-3">
                <div class="form-check form-checkform-check-inline">
                    
                    <input class="form-check-input" asp-for="IsInterestedInTANF">
                    <label class="form-check-label" asp-for="IsInterestedInTANF">TANF</label>
                </div>
            </div>
       </div>

       <div class="d-flex justify-content-center align-items-center vh-50">
            <div class="d-grid gap-2">
                <button id="nextButtonUserApp" class="btn btn-custom-blue" type="submit" style="width: 500px; margin-bottom: 100px; margin-top: 25px">Next</button>
            </div>
        </div>


            @* <script>
                // JavaScript to handle button click event
                document.getElementById("nextButton").addEventListener("click", function () {
                    window.location.href = '@Url.Action("userApplicationForm", "Registration")';
                });
            </script> *@
    </form>

    <script>
        // JavaScript to handle button click event
        document.getElementById("nextButtonUserApp").addEventListener("Click", function () {

            var studentId = document.getElementById('UserID').value;
            localStorage.setItem('passStudentId', studentId);

            var firstName = document.getElementById('FirstName').value;
            localStorage.setItem('passFirstName', firstName);

            var lastName = document.getElementById('LastName').value;
            localStorage.setItem('passLastName', lastName);
        });
    </script>

</div>