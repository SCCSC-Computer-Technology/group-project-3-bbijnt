@model Donation
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Donation Form</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/5.0.0/css/bootstrap.min.css">
    <style>
        .btn-custom-blue {
            background-color: #242c5c;
            border-color: #242c5c;
            color: white;
        }

        .btn-custom-blue:hover {
            background-color: #349444;
            border-color: #349444;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">

        <div class="d-flex align-items-center">
            <img src="/Images/logo.png" class="img-thumbnail d-inline me-4" alt="Chaser Logo" style="max-width: 300px" />
        </div>
        <h1 class="text-end mb-5">DONATION <span class="text-success">FORM</span></h1>

        @using (Html.BeginForm("DonationForm", "Staff", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="row mb-4">
                <label for="Company" class="col-sm-2 col-form-label">
                    Company Name:
                </label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" id="Company" name="Company" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="firstName" class="col-sm-2 col-form-label">
                    First Name:
                </label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" id="FirstName" name="FirstName" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="MidName" class="col-sm-2 col-form-label">
                    Middle Name:
                </label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" id="MidName" name="MidName" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="LastName" class="col-sm-2 col-form-label">
                    Last Name:
                </label>
                <div class="col-sm-8">
                    <input type="text" class="form-control" id="LastName" name="LastName" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="donationType" class="col-sm-2 col-form-label">
                    Donation Type:
                </label>
                <div class="col-sm-8">
                    <select class="form-select" id="Type" name="Type" required>
                        <option value="">Select donation type</option>
                        <option value="Non-Food">Non-food</option>
                        <option value="Food">Food</option>
                        <option value="Produce">Produce</option>
                        <option value="Monetary">Monetary</option>
                        <option value="Grab-N-Go">Grab-N-Go</option>
                    </select>
                </div>
            </div>

            <div class="row mb-4">
                <label for="donationValue" class="col-sm-2 col-form-label">
                    Donation Value:
                </label>
                <div class="col-sm-8">
                    <input type="number" class="form-control" id="Value" name="Value" placeholder="Enter amount" min="0" step="0.01" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="donationQuantity" class="col-sm-2 col-form-label">
                    Donation Quantity:
                </label>
                <div class="col-sm-8">
                    <input type="number" class="form-control" id="Quantity" name="Quantity" placeholder="Enter quantity" min="0" step="0.01" required>
                </div>
            </div>

            <div class="row mb-4">
                <label for="notes" class="col-sm-2 col-form-label">
                    Notes:
                </label>
                <div class="col-sm-8">
                    <textarea class="form-control" id="Notes" name="Notes" rows="5" placeholder="Enter your notes here."></textarea>
                </div>
            </div>

            <div class="d-flex justify-content-center align-items-center vh-50">
                <div class="d-grid gap-2">
                    <button id="submitButtonDonation" class="btn btn-custom-blue" type="submit" style="width: 500px; margin-bottom: 100px; margin-top: 25px">Submit</button>
                </div>
            </div>
        }
    </div>
</body>
</html>
