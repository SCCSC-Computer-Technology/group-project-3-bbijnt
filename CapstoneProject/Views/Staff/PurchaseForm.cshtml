@model Purchasing
@{
    ViewData["Title"] = "Purchase Form";
}

<head>
    <style>
        .btn-custom-blue {
            background-color: #242c5c;
            border-color: #242c5c;
            color: white;
        }

            .btn-custom-blue:hover {
                background-color: #349444;
                border-color: #349444;
                color: white;
            }
    </style>
</head>

<div class="d-flex align-items-center">
    <img src="/Images/ChaserLogo.png" class="img-thumbnail d-inline me-4" alt="Chaser Logo" />
    <div>
        <h3>SCC</h3>
        <p>FOOD PANTRY</p>
    </div>
</div>

<h1 class="text-end">PURCHASE<span class="text-secondary">   FORM</span></h1>
<h2 class="mb-4">Please provide the following information:</h2>

<form method="post">

    <div class="row mb-4">
        <label asp-for="StoreName" class="col-sm-2 col-form-label">
            Store Name:
        </label>
        <div class="col-sm-8">
            <input asp-for="StoreName" class="form-control" placeholder="Store Name" />
            <span asp-validation-for="StoreName" class="text-danger"></span>
        </div>
    </div>


    <div class="row mb-4">
        <label asp-for="ShopTransactionID" class="col-sm-2 col-form-label">
            Shop Transaction ID:
        </label>
        <div class="col-sm-8">
            <input asp-for="ShopTransactionID" class="form-control" placeholder="Shop Transaction ID" />
            <span asp-validation-for="ShopTransactionID" class="text-danger"></span>
        </div>
    </div>

    <div class="row mb-4">
        <label for="PaymentMethod" class="col-sm-2 col-form-label">
            Payment Method:
        </label>
        <div class="col-sm-8">
            <select class="form-select" id="PaymentMethod" name="PaymentMethod" required>
                <option value="">Select payment method</option>
                <option value="Cdt">Credit</option>
                <option value="Debit">Debit</option>
                <option value="Gift">Gift Card</option>
                <option value="Cash">Cash</option>
            </select>
        </div>
    </div>

    <div class="row mb-4">
        <label for="TotalSpent" class="col-sm-2 col-form-label">
            Total Spent:
        </label>
        <div class="col-sm-8">
            <input type="number" class="form-control" id="TotalSpent" name="TotalSpent" placeholder="Enter amount" min="0" step="0.01" required>
        </div>
    </div>

    <div class="row mb-4">
        <label asp-for="Date" class="col-sm-2 col-form-label">
            Date:
        </label>
        <div class="col-sm-8">
            <input asp-for="Date" class="form-control" type="date" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex justify-content-center align-items-center vh-50">
        <div class="d-grid gap-2">
            <button id="submitButtonRequest" class="btn btn-custom-blue" type="submit" style="width: 500px; margin-bottom: 100px; margin-top: 25px">Submit</button>
        </div>
    </div>


    @* <script>
    // JavaScript to handle button click event
    document.getElementById("nextButton").addEventListener("click", function () {
    window.location.href = '@Url.Action("userApplicationForm", "Registration")';
    });
    </script> *@

</form>

