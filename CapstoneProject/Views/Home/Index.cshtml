@{
    ViewData["Title"] = "Home Page";
}

<div class="container text-center">
    <div class="row justify-content-center align-items-center">
        <div class="col-md-6">
            <img src="/Images/logo.png" class="img-thumbnail img-fluid chaser-img" alt="Chaser Pantry" style="max-width: 300px;">
        </div>
        <div class="col-md-6">
            <figure class="text-center">
                <blockquote class="blockquote">
                    <p>Because going hungry should never affect a student's ability to attend class and learn.</p>
                </blockquote>
                <figcaption class="blockquote-footer">
                    Chaser from <cite title="Source Title">Spartanburg Community College</cite>
                </figcaption>
            </figure>
        </div>
    </div>
</div>


<div id="LandingPageSlideshow" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/Images/Team.jpg" class="d-block w-100" alt="Pantry Team Picture">
        </div>
        <div class="carousel-item">
            <img src="/Images/Pantry.jpg" class="d-block w-100" alt="Inside Pantry Picture">
        </div>
        <div class="carousel-item">
            <img src="/Images/Check.jpg" class="d-block w-100" alt="Food Lion Check">
        </div>
        <div class="carousel-item">
            <img src="/Images/Pair.jpg" class="d-block w-100" alt="Leaders of Pantry">
        </div>
        <div class="carousel-item">
            <img src="/Images/Chaser.jpg" class="d-block w-100" alt="Chaser in Pantry">
        </div>
    </div>
</div>

