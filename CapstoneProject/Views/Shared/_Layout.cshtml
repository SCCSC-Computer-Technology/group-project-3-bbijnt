<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CapstoneProject</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CapstoneProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css">
</head>

<style>
    .navbar-toggler .bi-list {
        color: #fff; 
        font-size: 1.5rem;
    }
</style>
<body>
    <header>
        @if (User.Identity.IsAuthenticated)
        {
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3" style="background-color: #242c5c">
                <div class="container-fluid">
                    <img src="/Images/SCC-logo.png" class="img-thumbnail d-inline me-4" alt="SCC Logo">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"><i class="bi bi-list"></i></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">
                        <ul class="navbar-nav ms-sm-auto justify-content-center">
                            <li class="nav-item">
                            <a class="nav-link text-white"  asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        
                        @if (!User.IsInRole("Admin") && !User.IsInRole("Staff"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Registration" asp-action="WelcomePageView">New User</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="User" asp-action="AidForm">Receive Aid</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Staff
                                </a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="DonationForm">Donation Form</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="PurchaseForm">Purchase Form</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="RequestForm">Request Form</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="UpdateLiabilityForm">Liability Form</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="ViewRequests">Requests</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Staff" asp-action="FindUser">User Details</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Reports" asp-action="ReportsForm">Reports</a>
                                    <a class="dropdown-item text-black" asp-area="" asp-controller="Inventory" asp-action="Index">Inventory</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="dropdown-item text-black" asp-area="Identity" asp-page="/Account/ManageUsers">User Management</a>
                                    }
                                </div>
                            </li>
                        }
                            <li class="nav-item">
                                <a class="nav-link text-white" href="/Identity/Account/Logout">Logout</a>
                            </li>
                    </ul>
						<span class="container text-end justify-content-center">
                            <img src="/Images/chaser-logo.png" class="img-thumbnail d-inline me-4" alt="SCC Logo" style="max-height: 75px">
                            @* <p class="food-pantry-text">Food Pantry</p> *@
                        </span>
                    </div>
                </div>
            </nav>
        }
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="footer footer-green">
        <div class="container">
            <p>This comment is to make the green footer appear</p>
        </div>
    </footer>

    <footer class="border-top footer text-muted" style="background-color: #242c5c">
        <div class="container text-end">
            <p>Courtesy of the 2024 Capstone Students</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
