@model Item

<div style="margin-bottom: 16px;">
    <a class="btn btn-secondary" href="javascript:history.back()">Back</a>
</div>
<div class="d-flex align-items-center">
    <img src="/Images/logo.png" class="img-thumbnail d-inline me-4" alt="Chaser Logo" style="max-width: 300px;">
</div>

<div class="container d-flex justify-content-center ">
    @* <img src="/Images/logo.png" class="img-thumbnail d-inline me-4" alt="Chaser Logo" style="max-width: 300px;"> *@
    <form method="post" class="col-md-6 mt-3">
        <div class="mb-3 row p-2">
            <label class="p-0" asp-for="UUID"></label>
            <input autofocus asp-for="UUID" class="form-control"  asp-route-UUID="UUID" minLength ="12" maxlength="12" required/>
            <span asp-validation-for="UUID" class="text-danger"></span>
        </div>
        <div class="col-6 col-md-3">
            <button type="submit" class=" btn btn-primary form-control ">LookUP</button>
        </div>
    </form>

</div>
<hr />
<div>
    <partial name="_Inventory" model="ViewBag.InventoryList" />
</div>