@model CapstoneProject.Models.Item

<form method="post" asp-action="Delete">
    <input asp-for="ItemID" type="hidden" name="id" />

    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Delete Item</h2>
            <hr />
        </div>

        <div class="mb-3 row p-1">
            <label class="p-0">Item ID</label>
            <input value="@Model.ItemID" disabled class="form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label class="p-0">Description</label>
            <input value="@Model.Description" disabled class="form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label class="p-0">Subcategory</label>
            <input value="@Model.ItemSubcategory?.Name" disabled class="form-control" />
        </div>

        <div class="mb-3 row p-1">
            <label class="p-0">Quantity</label>
            <input value="@Model.Quantity" disabled class="form-control" />
        </div>

        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Delete Item</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-action="Index" class="btn btn-secondary form-control">Back</a>
            </div>
        </div>
    </div>
</form>