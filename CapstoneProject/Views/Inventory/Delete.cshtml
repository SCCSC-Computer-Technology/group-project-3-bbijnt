@model Item


<form method="post">
    <input asp-for="ItemID" hidden />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Delete Item</h2>
            <hr />
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="ItemID"></label>
            <input asp-for="ItemID" disabled class="form-control" />
            
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="Description"></label>
            <input asp-for="Description" disabled class="form-control" />
            
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0">Subcategory</label>
            <input value="@ViewBag.SubcategoryName" disabled class="form-control" />
        </div>
        <div class="mb-3 row p-1">
            <label class="p-0" asp-for="Quantity"></label>
            <input asp-for="Quantity" disabled class="form-control" />
    
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Delete Item</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Inventory" asp-action="Index" class="btn btn-secondary form-control">Back</a>
            </div>
        </div>

    </div>
</form>




