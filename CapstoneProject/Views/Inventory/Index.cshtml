@model List<CapstoneProject.Models.Item>
<head>
    <style>
        .btn-custom-blue {
            background-color: #242c5c;
            border-color: #242c5c;
            color: white;
            width: 25%;
        }

        .btn-custom-blue:hover {
            background-color: #349444;
            border-color: #349444;
            color: white;
        }

        .btn-container {
            display: flex;
            flex-direction: row;
            gap: 50px;
            justify-self: center;
            justify-content: center;
            width: 80%;
        }

        .table-scrollable {
                max-height: 400px;
                overflow-y: auto;
                overflow-x: auto;
        }


        @@media (width <= 500px) {
            .btn-container {
                flex-direction: column;
            }

            .btn-custom-blue {
                width: 75%;
            }
        }
    </style>
</head>﻿

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Inventory</h2>
        <a asp-action="Create" class="btn btn-primary">Add New Item</a>
    </div>

    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">
            @TempData["success"]
        </div>
    }
<div class="table-scrollable">
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Item ID</th>
                <th>UUID</th>
                <th>Description</th>
                <th>Subcategory</th>
                <th>Quantity</th>
                <th>Point Cost</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ItemID</td>
                    <td>@item.UUID</td>
                    <td>@item.Description</td>
                    <td>@item.ItemSubcategory?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.PointCost</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.ItemID" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ItemID" class="btn btn-sm btn-danger">Delete</a>
                        <a asp-action="GetBarCodeImage" asp-route-id="@item.ItemID" class="btn btn-sm btn-info">View Barcode</a>
                    </td>
                </tr>
            }
          </tbody>
      </table>
    </div>
</div>