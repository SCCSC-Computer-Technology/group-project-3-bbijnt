@model StaffSignIn

@{
    var errorMessage = TempData["ErrorMessage"] as string;
}

<head>
    <style>
        .btn-custom-blue {
            background-color: #242c5c;
            border-color: #242c5c;
            color: white;
        }

        .btn-custom-blue:hover {
                background-color: #404fa5;
                border-color: #404fa5;
            color: white;
        }

        .btn-custom-green {
            background-color: #349444;
            border-color: #349444;
            color: white;
        }

        .btn-custom-green:hover {
                background-color: #287134;
                border-color: #287134;
            color: white;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>

<div class="text-center">
    <div class="d-flex align-items-center">
        <div class="container text-center">
            <img src="/Images/logo.png" class="img-thumbnail img-fluid chaser-img" alt="Chaser Pantry" style="max-width: 350px;">
            <p class="fs-5"><br />Welcome to the SCC Food Pantry!<br /> Please sign in.</p>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<form asp-action="Login" method="post">
    <div class="container">
        <div class="row justify-content-center align-items-center" style="height: 60vh;">
            <div class="col-lg-4 p-4 border bg-light rounded">
                <h1 class="text-center mb-4">Staff Login</h1>
                @* Display validation errors *@
                <div asp-validation-summary="All" class="text-danger"></div>

                @* Display error message from ViewBag *@
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                }

                @*ID Field *@
                <label for="id" class="form-label">School ID</label>
                <input type="text" class="form-control mb-3" asp-for="UserID" placeholder="School ID" />

                @* Password field *@
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control mb-3" asp-for="Password" placeholder="Password" />

                @* Submit button *@
                <div class="d-grid gap-2">
                    <button class="btn btn-custom-blue" type="submit">Sign In</button>
                    <a class="btn btn-custom-green" asp-controller="Login" asp-action="SignUp">Sign Up</a>
                </div>
                <hr />
                <button type="button" class="btn btn-outline-primary w-100 mt-2" data-bs-toggle="modal" data-bs-target="#ssoModal">
                    Login with SCC (Demo)
                </button>
            </div>
        </div>
    </div>
</form>

<!-- SSO Modal -->
<div class="modal fade" id="ssoModal" tabindex="-1" aria-labelledby="ssoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="ssoModalLabel">Select Demo SCC User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <form id="ssoForm" asp-action="DemoSccLogin" method="post">
            <input type="hidden" id="userTypeInput" name="userType" value="student" />
            <button type="submit" class="btn btn-success w-75 mb-2" onclick="document.getElementById('userTypeInput').value='student'">Login as Student (sccstudent@scc.edu)</button>
            <button type="submit" class="btn btn-info w-75" onclick="document.getElementById('userTypeInput').value='admin'">Login as Admin (admin@scc.edu)</button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
