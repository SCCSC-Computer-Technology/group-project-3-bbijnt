@model List<ItemCategory>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div style="margin-bottom: 16px;">
    <a class="btn btn-secondary" href="javascript:history.back()">Back</a>
</div>
<div class="container">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">Categories</h2>
        </div>
    </div>

    <div class="col-6 col-md-3" style="justify-self:center; margin-bottom: 12px;">
        <a class="btn btn-primary form-control" asp-controller="Categories" asp-action="Add">Add Category</a>
    </div>

    <div style="overflow-y: scroll; height: 500px;">
        <table class="table table-bordered table-striped">
            <thread>
                <tr>
                    <th>
                        Category Name
                    </th>
                    <th>
                        <!--Empty for formatting-->
                    </th>
            </thread>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td>@obj.Name</td>
                        <td>
                            <div class="w-100 btn-group" role="group">
                                <a asp-controller="Categories" asp-action="Edit" asp-route-id="@obj.CategoryID" class="btn btn-primary mx-2">
                                    <i class="bi bi-pencil-square"></i>Edit
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>


        </table>
    </div>
</div>