@page
@model CapstoneProject.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in to Spartanburg Community College";
}

<div class="min-h-screen bg-white flex items-center justify-center p-4">
    <div class="bg-gray-50 shadow-2xl rounded-xl max-w-md w-full p-8">
        <div class="text-center mb-6">
            <div class="inline-block p-4 bg-[#005596] rounded-full border border-gray-300">
                <img src="~/Images/SCC-logo.png" alt="Spartanburg Community College Logo" class="h-10 mx-auto" />
            </div>
        </div>

        <section>
            <form id="account" method="post" class="space-y-6">
                <h2 class="text-xl font-semibold text-gray-800">Sign in with your SCC ID</h2>
                <hr class="border-gray-300" />
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm" role="alert"></div>
                <div class="relative">
                    <input asp-for="Input.StudentId" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="username" aria-required="true" placeholder="0214365" maxlength="7" />
                    <label asp-for="Input.StudentId" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Student ID</label>
                    <span asp-validation-for="Input.StudentId" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.Password" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="password" aria-required="true" placeholder="Enter your password" type="password" />
                    <label asp-for="Input.Password" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Password</label>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
                </div>
                <div class="flex items-center">
                    <input asp-for="Input.RememberMe" class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" />
                    <label asp-for="Input.RememberMe" class="ml-2 block text-sm text-gray-900">Remember me</label>
                </div>
                <button id="login-submit" type="submit" class="w-full bg-blue-600 text-white py-3 rounded-md hover:bg-blue-700 transition duration-200">Sign In</button>
                <div class="text-center space-y-2">
                    <p class="text-sm">
                        <a asp-area="Identity" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-blue-600 hover:underline">Register as a new student</a>
                    </p>
                </div>
                <hr />
                <button type="button" class="w-full bg-green-600 text-white py-3 rounded-md hover:bg-green-700 transition duration-200 mt-2" data-bs-toggle="modal" data-bs-target="#ssoModal">
                    Login with SCC (Demo)
                </button>
            </form>
        </section>

        @if (Model.ExternalLogins?.Count > 0)
        {
            <section class="mt-8">
                <h3 class="text-lg font-semibold text-gray-800 text-center">Or sign in with another service</h3>
                <hr class="border-gray-300 my-4" />
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-wrap justify-center gap-4">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="bg-gray-200 text-gray-800 px-4 py-2 rounded-md hover:bg-gray-300 transition duration-200" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">@provider.DisplayName</button>
                    }
                </form>
            </section>
        }
    </div>
</div>

<!-- SSO Modal -->
<div class="modal fade" id="ssoModal" tabindex="-1" aria-labelledby="ssoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="ssoModalLabel">Select Demo SCC User</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <form id="ssoForm" method="post">
            <input type="hidden" id="userTypeInput" name="userType" value="student" />
            <button type="submit" class="btn btn-success w-75 mb-2" formaction="?handler=DemoSccLogin" onclick="document.getElementById('userTypeInput').value='student'">Login as Student (sccstudent@scc.edu)</button>
            <button type="submit" class="btn btn-info w-75" formaction="?handler=DemoSccLogin" onclick="document.getElementById('userTypeInput').value='admin'">Login as Admin (admin@scc.edu)</button>
        </form>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
}