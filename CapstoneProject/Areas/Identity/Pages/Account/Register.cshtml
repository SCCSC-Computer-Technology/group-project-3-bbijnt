@page
@model CapstoneProject.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Register for Spartanburg Community College";
}

<div class="min-h-screen bg-white flex items-center justify-center p-4">
    <div class="bg-gray-50 shadow-2xl rounded-xl max-w-md w-full p-8">
        <div class="text-center mb-6">
            <div class="inline-block p-4 bg-[#005596] rounded-full border border-gray-300">
                <img src="~/Images/SCC-logo.png" alt="Spartanburg Community College Logo" class="h-10 mx-auto" />
            </div>
        </div>

        <section>
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-20 space-y-6">
                <h2 class="text-xl font-semibold text-gray-800">Create a new SCC account</h2>
                <hr class="border-gray-300" />
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm" role="alert"></div>
                <div class="relative">
                    <input asp-for="Input.StudentId" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="username" aria-required="true" placeholder="0214365" maxlength="7" />
                    <label asp-for="Input.StudentId" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Student ID</label>
                    <span asp-validation-for="Input.StudentId" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.FirstName" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="first-name" aria-required="true" placeholder="First" />
                    <label asp-for="Input.FirstName" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">First Name</label>
                    <span asp-validation-for="Input.FirstName" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.LastName" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="last-name" aria-required="true" placeholder="Last" />
                    <label asp-for="Input.LastName" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Last Name</label>
                    <span asp-validation-for="Input.LastName" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.Email" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Email</label>
                    <span asp-validation-for="Input.Email" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.Password" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="new-password" aria-required="true" placeholder="Password" />
                    <label asp-for="Input.Password" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Password</label>
                    <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
                </div>
                <div class="relative">
                    <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" />
                    <label asp-for="Input.ConfirmPassword" class="absolute -top-2 left-3 bg-gray-50 px-1 text-sm text-gray-600">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-sm"></span>
                </div>
                <button id="registerSubmit" type="submit" class="w-full bg-blue-600 text-white py-3 rounded-md hover:bg-blue-700 transition duration-200">Register</button>
            </form>
        </section>

        @if (Model.ExternalLogins?.Count > 0)
        {
            <section class="mt-8">
                <h3 class="text-lg font-semibold text-gray-800 text-center">Or register with another service</h3>
                <hr class="border-gray-300 my-4" />
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-wrap justify-center gap-4">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="bg-gray-200 text-gray-800 px-4 py-2 rounded-md hover:bg-gray-300 transition duration-200" name="provider" value="@provider.Name" title="Register using your @provider.DisplayName account">@provider.DisplayName</button>
                    }
                </form>
            </section>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.tailwindcss.com"></script>
}